# ── Auth ──────────────────────────────────────────────────────────────────────
# Password to log into the app. Set a strong value in Vercel dashboard.
ADMIN_PASSWORD=your-strong-password-here

# ── Vercel Postgres ────────────────────────────────────────────────────────────
# These are set automatically when you add Vercel Postgres to your project.
# For local dev: run `vercel env pull .env.local` after linking your project.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
