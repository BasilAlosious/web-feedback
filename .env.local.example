# ── Auth ──────────────────────────────────────────────────────────────────────
# Password to log into the app. Set a strong value in Vercel dashboard.
ADMIN_PASSWORD=your-strong-password-here

# Secret used to sign session cookies. Generate a random string for production.
# Without this, a hardcoded fallback is used (insecure for production).
SESSION_SECRET=

# ── Vercel Postgres ────────────────────────────────────────────────────────────
# These are set automatically when you add Vercel Postgres to your project.
# For local dev: run `vercel env pull .env.local` after linking your project.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
